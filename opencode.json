{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      ".local/skills",
      ".local/secondary_skills"
    ]
  },
  
  "permission": {
    "*": "ask",
    "skills": "allow",
    "tools": "allow",
    "todowriter": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "npm run*": "ask",
      "pytest*": "allow",
      "rm *": "ask",
      "sudo *": "deny"
    },
    "edit": "ask"
  }
}
